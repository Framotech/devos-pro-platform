# DevOS Pro Platform environment template.
# Copy to a local .env file when needed, but never commit real secrets.

# Database
# Required by src/lib/db.ts for all MongoDB-backed API routes and CMS data.
MONGODB_URI=

# Clerk authentication
# Required by @clerk/nextjs provider and middleware in protected admin routes.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/admin/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin/dashboard

# Email / notifications
# Reserved for contact, notification, and creator-support email flows.
RESEND_API_KEY=

# Application URL
# Used by deployment workflows and future absolute URL generation.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Future media storage abstraction
# local keeps uploads on the application filesystem; cloud providers can be added without changing CMS modules.
MEDIA_STORAGE_DRIVER=local
MEDIA_UPLOAD_DIR=public/uploads
NEXT_PUBLIC_MEDIA_BASE_URL=/uploads
